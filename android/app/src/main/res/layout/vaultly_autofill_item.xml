<?xml version="1.0" encoding="utf-8"?>
<!-- Row shown inside another app's autofill dropdown: app icon + label.
     Must stay RemoteViews-compatible (basic views only). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/vaultly_autofill_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:importantForAccessibility="no"
        android:src="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/vaultly_autofill_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorPrimary"
        android:text="Unlock Vaultly to fill" />
</LinearLayout>
